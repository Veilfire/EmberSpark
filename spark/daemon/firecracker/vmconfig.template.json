{
  "boot-source": {
    "kernel_image_path": "{{ kernel }}",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off nomodules ro root=/dev/vda ip={{ guest_ip }}::{{ gateway }}:255.255.255.252::eth0:off"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "{{ rootfs }}",
      "is_root_device": true,
      "is_read_only": false
    },
    {
      "drive_id": "spark_data",
      "path_on_host": "{{ data_image }}",
      "is_root_device": false,
      "is_read_only": false
    }
  ],
  "machine-config": {
    "vcpu_count": {{ vcpus }},
    "mem_size_mib": {{ memory_mib }},
    "smt": false
  },
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "host_dev_name": "{{ tap }}",
      "guest_mac": "AA:FC:00:00:00:01"
    }
  ],
  "vsock": {
    "guest_cid": {{ vsock_cid }},
    "uds_path": "{{ vsock_path }}"
  }
}
